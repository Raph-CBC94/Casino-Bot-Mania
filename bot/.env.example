# Token du bot Discord (obligatoire)
DISCORD_TOKEN=ton_token_ici

# ID de l'application Discord (obligatoire pour déployer les commandes)
CLIENT_ID=ton_client_id_ici

# ID du serveur Discord pour déploiement instantané des commandes (optionnel)
GUILD_ID=ton_guild_id_ici

# Chemin vers la base de données SQLite (optionnel, défaut: ./data/casino.db)
# Sur Render avec disque persistant, utiliser: /var/data/casino.db
# DB_PATH=/var/data/casino.db
